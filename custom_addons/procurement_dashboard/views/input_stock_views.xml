<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="action_stock_input_form" model="ir.actions.act_window">
            <field name="name">Input Stok Bahan Baku</field>
            <field name="res_model">stock.input.material</field>
            <field name="view_mode">form,tree</field>
        </record>

        <!-- Form View untuk Input Stok -->
        <record id="view_stock_input_form" model="ir.ui.view">
            <field name="name">stock.input.material.form</field>
            <field name="model">stock.input.material</field>
            <field name="arch" type="xml">
                <form string="Input Stok Bahan Baku">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="date" widget="datetime"/>
                                <field name="material_id" options="{'no_open': False, 'no_create': False}"/>
                                <field name="transaction_type"/>
                            </group>
                            <group>
                                <field name="current_stock" readonly="1" widget="integer"/>
                                <field name="quantity" widget="integer"/>
                                <field name="unit" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="stock_after" readonly="1" widget="integer"/>
                            <field name="created_by" readonly="1"/>
                        </group>
                        <group>
                            <field name="notes" placeholder="Tambahkan catatan perubahan stok..."/>
                        </group>
                        <footer>
                            <button name="action_confirm" string="Simpan Perubahan Stok" type="object" class="oe_highlight"/>
                            <button string="Batal" class="oe_link" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Tree View untuk Riwayat Input Stok -->
        <record id="view_stock_input_tree" model="ir.ui.view">
            <field name="name">stock.input.material.tree</field>
            <field name="model">stock.input.material</field>
            <field name="arch" type="xml">
                <tree string="Riwayat Input Stok" create="false" delete="false">
                    <field name="date"/>
                    <field name="material_id"/>
                    <field name="transaction_type"/>
                    <field name="quantity"/>
                    <field name="current_stock"/>
                    <field name="stock_after"/>
                    <field name="created_by"/>
                </tree>
            </field>
        </record>

        <!-- Tree View untuk History -->
        <record id="view_stock_input_history_tree" model="ir.ui.view">
            <field name="name">stock.input.history.tree</field>
            <field name="model">stock.input.history</field>
            <field name="arch" type="xml">
                <tree string="Riwayat Lengkap Input Stok" create="false" delete="false">
                    <field name="date"/>
                    <field name="material_name"/>
                    <field name="transaction_type"/>
                    <field name="quantity"/>
                    <field name="unit"/>
                    <field name="stock_before"/>
                    <field name="stock_after"/>
                    <field name="created_by"/>
                </tree>
            </field>
        </record>

        <!-- Action untuk History -->
        <record id="action_stock_input_history" model="ir.actions.act_window">
            <field name="name">Riwayat Input Stok</field>
            <field name="res_model">stock.input.material</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
