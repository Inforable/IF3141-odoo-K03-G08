<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Access Control for stock.input.history -->
        <record id="access_stock_input_history_read" model="ir.model.access">
            <field name="name">stock.input.history read</field>
            <field name="model_id" ref="model_stock_input_history"/>
            <field name="group_id" ref="base.group_user"/>
            <field name="perm_read">1</field>
            <field name="perm_write">0</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="access_stock_input_history_all" model="ir.model.access">
            <field name="name">stock.input.history all</field>
            <field name="model_id" ref="model_stock_input_history"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>

        <!-- Access Control for bahan.baku -->
        <record id="access_bahan_baku_read" model="ir.model.access">
            <field name="name">bahan.baku read write</field>
            <field name="model_id" ref="model_bahan_baku"/>
            <field name="group_id" ref="base.group_user"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">0</field>
        </record>

        <record id="access_bahan_baku_all" model="ir.model.access">
            <field name="name">bahan.baku all</field>
            <field name="model_id" ref="model_bahan_baku"/>
            <field name="perm_read">1</field>
            <field name="perm_write">1</field>
            <field name="perm_create">1</field>
            <field name="perm_unlink">1</field>
        </record>
    </data>
</odoo>
